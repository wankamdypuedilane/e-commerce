# Copy this file to terraform.tfvars and adjust values.
project_name      = "dilane-shop"
environment       = "prod"
aws_region        = "eu-west-3"
instance_type     = "t3.micro"
root_volume_size  = 8

# Must match an existing EC2 key pair name in AWS.
ssh_key_name      = "dilane-shop"

# Restrict SSH to your own public IP CIDR.
ssh_allowed_cidr  = "203.0.113.10/32"

# Optional. Keep null to use default VPC/subnet.
vpc_id            = null
subnet_id         = null
