# Copiez ce fichier vers .env et remplissez les valeurs
# cp .env.example .env

# Django (securite)
DJANGO_SECRET_KEY=remplace_par_une_cle_secrete_longue
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Login SMTP Brevo (souvent l'email de connexion Brevo)
BREVO_SMTP_LOGIN=votre_login_brevo

# Cle SMTP Brevo (SMTP Key)
BREVO_SMTP_KEY=votre_cle_smtp_brevo

# Email expediteur verifie dans Brevo
EMAIL_FROM=votre_email@gmail.com

# Stripe (paiement)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# Base de donnees (production recommande: PostgreSQL)
# sqlite (defaut local): DB_ENGINE=sqlite
# postgres (prod): DB_ENGINE=postgres
DB_ENGINE=sqlite
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Facturation
TAX_RATE_PERCENT=20
